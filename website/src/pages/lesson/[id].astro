---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import AIAssistant from '../../components/AIAssistant.astro';
import { parseSections, extractSourceUrl, parseComprehension, annotateArticle } from '../../lib/lesson-parser';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons');
  return lessons.map(lesson => ({
    params: { id: lesson.id },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const sections = parseSections(lesson.body ?? '');
const sourceUrl = extractSourceUrl(sections.article);
const qaBlocks = parseComprehension(sections.comprehension);

function parseVocabEntries(vocabularyText: string) {
  const entries = [];
  if (!vocabularyText.trim()) return entries;
  const lines = vocabularyText.split('\n');
  let currentEntry = null;
  for (const line of lines) {
    if (line.startsWith('**') && line.includes('**') && line.includes('(') && line.includes(')')) {
      const match = line.match(/\*\*(.*?)\*\*\s*\((.*?)\)\s*(?:\/([^/]+)\/)?\s*（(.*?)）\s*—\s*(.*)/);
      if (match) {
        currentEntry = { word: match[1], pos: match[2], ipa: match[3] || '', chinese: match[4], definition: match[5], quote: '' };
        entries.push(currentEntry);
      }
    } else if (line.startsWith('>') && currentEntry) {
      currentEntry.quote = line.replace(/^>\s*"?/, '').replace(/"?\s*$/, '');
    }
  }
  return entries;
}

function toSlug(word: string): string {
  return word.toLowerCase().replace(/[^a-z0-9]/g, '_');
}

function parseExpressionEntries(expressionsText: string) {
  const entries = [];
  if (!expressionsText.trim()) return entries;
  const blocks = expressionsText.split(/(?=\*\*[^*]+\*\*\s*（)/);
  for (const block of blocks) {
    if (!block.trim()) continue;
    const lines = block.trim().split('\n');
    const headerMatch = lines[0]?.match(/\*\*(.*?)\*\*\s*（(.*?)）/);
    if (headerMatch) {
      const phrase = headerMatch[1];
      const chinese = headerMatch[2];
      const explanation = [];
      const examples = [];
      for (let i = 1; i < lines.length; i++) {
        const line = lines[i].trim();
        if (line.startsWith('-')) { examples.push(line.substring(1).trim()); }
        else if (line && !line.startsWith('**')) { explanation.push(line); }
      }
      entries.push({ phrase, chinese, explanation: explanation.join(' '), examples });
    }
  }
  return entries;
}

const vocabEntries = parseVocabEntries(sections.vocabulary);
const expressionEntries = parseExpressionEntries(sections.expressions);

function processArticleText(articleText: string): string[] {
  if (!articleText) return [];
  return articleText
    .split('\n\n')
    .filter(para => para.trim())
    .filter(para => !para.match(/^\d{2}-\d{2}-\d{4}/))
    .filter(para => !para.startsWith('> Source:'))
    .filter(para => !para.startsWith('Difficult words:'))
    .filter(para => !para.startsWith('You can watch'))
    .filter(para => !para.startsWith('The post'))
    .map(para => para.trim())
    .filter(para => para.length > 0);
}

const articleParagraphs = processArticleText(sections.article);
const base = import.meta.env.BASE_URL?.replace(/\/$/, '') || '';
---

<Base title={lesson.id}>
  <!-- Back link -->
  <a href={`${base}/`} class="back-link">← 返回首页</a>

  <!-- Lesson header -->
  <div class="lesson-header">
    <div class="lesson-date-row">
      <span class="lesson-date-tag">{lesson.id}</span>
    </div>
  </div>

  <!-- Article card -->
  <div class="card card-padding" style="margin-bottom: 12px;">
    <div class="article-audio-bar">
      <button class="audio-btn" data-src={`/audio/${lesson.id}/article.mp3`}>🔊 朗读全文</button>
    </div>
    <div class="link-toggle-row">
      <button class="anno-btn btn-link" data-hide="linking">⌣ 连读</button>
      <button class="anno-btn btn-stress" data-hide="stress">ˈ 重音</button>
      <button class="anno-btn btn-tone" data-hide="intonation">↗↘ 语调</button>
    </div>
    <div class="article-body">
      {articleParagraphs.map(paragraph => (
        <p set:html={annotateArticle(paragraph)} />
      ))}
    </div>
    {sourceUrl && (
      <a href={sourceUrl} target="_blank" rel="noopener noreferrer" class="source-link">
        阅读原文 <span>→</span>
      </a>
    )}
  </div>

  <!-- Vocabulary Section -->
  <div class="section-block" data-collapsed="true">
    <button class="section-header">
      <div class="section-header-left">
        <span class="section-icon vocab-icon">📚</span>
        <span class="section-title">词汇 / Vocabulary</span>
        {vocabEntries.length > 0 && (
          <span class="section-count">{vocabEntries.length}</span>
        )}
      </div>
      <span class="section-chevron">▼</span>
    </button>
    <div class="section-body" style="grid-template-rows: 0fr">
      <div class="section-body-inner">
        <div class="section-content">
          {vocabEntries.map(entry => (
            <div class="vocab-entry">
              <div class="vocab-word-row">
                <span class="vocab-word">{entry.word}</span>
                <button class="audio-btn audio-icon" data-src={`/audio/${lesson.id}/vocab_${toSlug(entry.word)}.mp3`}>🔊</button>
                <span class="vocab-pos">{entry.pos}</span>
                {entry.ipa && <span class="vocab-ipa">/{entry.ipa}/</span>}
                <span class="vocab-zh">（{entry.chinese}）</span>
              </div>
              <div class="vocab-def">{entry.definition}</div>
              {entry.quote && (
                <div class="vocab-quote">
                  "{entry.quote}"
                  <button class="audio-btn audio-icon" data-src={`/audio/${lesson.id}/vocab_${toSlug(entry.word)}_ex.mp3`}>🔊</button>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Expressions Section -->
  <div class="section-block" data-collapsed="true">
    <button class="section-header">
      <div class="section-header-left">
        <span class="section-icon expr-icon">🔗</span>
        <span class="section-title">表达 / Chunking Expressions</span>
        {expressionEntries.length > 0 && (
          <span class="section-count">{expressionEntries.length}</span>
        )}
      </div>
      <span class="section-chevron">▼</span>
    </button>
    <div class="section-body" style="grid-template-rows: 0fr">
      <div class="section-body-inner">
        <div class="section-content">
          {expressionEntries.map(entry => (
            <div class="expr-entry">
              <div class="expr-phrase-row">
                <span class="expr-phrase">{entry.phrase}</span>
                <span class="expr-zh">（{entry.chinese}）</span>
              </div>
              {entry.explanation && (
                <div class="expr-explanation">{entry.explanation}</div>
              )}
              {entry.examples.length > 0 && (
                <ul class="expr-examples">
                  {entry.examples.map(example => (
                    <li>{example}</li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Comprehension Section -->
  <div class="section-block" data-collapsed="true">
    <button class="section-header">
      <div class="section-header-left">
        <span class="section-icon qa-icon">❓</span>
        <span class="section-title">理解 / Comprehension</span>
        {qaBlocks.length > 0 && (
          <span class="section-count">{qaBlocks.length}</span>
        )}
      </div>
      <span class="section-chevron">▼</span>
    </button>
    <div class="section-body" style="grid-template-rows: 0fr">
      <div class="section-body-inner">
        <div class="section-content">
          {qaBlocks.map((qa, i) => (
            <div class="qa-block">
              <div class="qa-question">
                <span class="qa-question-num">{i + 1}</span>
                <span>{qa.question}</span>
              </div>
              <div class="answer hidden">
                <div class="qa-answer">
                  <div class="qa-answer-en">{qa.answerEn}</div>
                  <div class="qa-answer-zh">{qa.answerZh}</div>
                </div>
              </div>
              <button class="reveal-btn">查看答案 ↓</button>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <AIAssistant
    articleContent={sections.article}
    vocabWords={vocabEntries.map(e => e.word)}
    base={base}
  />

  <script is:inline>
    document.querySelectorAll('.section-block').forEach(function(block) {
      var btn = block.querySelector('.section-header');
      var body = block.querySelector('.section-body');
      btn.addEventListener('click', function() {
        var collapsed = block.dataset.collapsed === 'true';
        body.style.gridTemplateRows = collapsed ? '1fr' : '0fr';
        block.dataset.collapsed = collapsed ? 'false' : 'true';
      });
    });

    document.querySelectorAll('.reveal-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var answer = btn.previousElementSibling;
        answer.classList.remove('hidden');
        btn.remove();
      });
    });

    (function() {
      var lessonId = document.querySelector('.lesson-date-tag')?.textContent?.trim() || '';
      try {
        var stored = JSON.parse(localStorage.getItem('read_lessons') || '[]');
        if (stored.indexOf(lessonId) === -1) {
          localStorage.setItem('read_lessons', JSON.stringify(stored.concat([lessonId])));
        }
      } catch(e) {}
    })();

    // Annotation toggles
    document.querySelectorAll('.anno-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var key = btn.dataset.hide;
        var isOff = btn.classList.toggle('is-off');
        document.body.classList.toggle('hide-' + key, isOff);
      });
    });

    // Audio playback
    var sharedAudio = new Audio();
    var activeAudioBtn = null;
    document.querySelectorAll('.audio-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var src = btn.dataset.src;
        if (!src) return;
        if (activeAudioBtn === btn && !sharedAudio.paused) {
          sharedAudio.pause();
          btn.textContent = btn.classList.contains('audio-icon') ? '🔊' : '🔊 朗读全文';
          activeAudioBtn = null;
          return;
        }
        if (activeAudioBtn) {
          activeAudioBtn.textContent = activeAudioBtn.classList.contains('audio-icon') ? '🔊' : '🔊 朗读全文';
        }
        sharedAudio.src = src;
        sharedAudio.play();
        btn.textContent = btn.classList.contains('audio-icon') ? '⏸' : '⏸ 暂停';
        activeAudioBtn = btn;
        sharedAudio.onended = function() {
          btn.textContent = btn.classList.contains('audio-icon') ? '🔊' : '🔊 朗读全文';
          activeAudioBtn = null;
        };
      });
    });
  </script>
</Base>
