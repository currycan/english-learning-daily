---
interface Props {
  title: string;
}
const { title } = Astro.props;
import '../styles/global.css';
const base = import.meta.env.BASE_URL?.replace(/\/$/, '') || '';
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Daily English</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href={`${base}/`} class="brand">
          <span class="brand-icon">EN</span>
          <span class="brand-name">Daily English</span>
        </a>
        <div class="header-right">
          <span class="header-date" id="js-header-date"></span>
        </div>
      </div>
    </header>
    <main class="page-main">
      <slot />
    </main>
    <script is:inline>
      (function() {
        var el = document.getElementById('js-header-date');
        if (!el) return;
        var d = new Date();
        var opts = { month: 'short', day: 'numeric', timeZone: 'Asia/Shanghai' };
        el.textContent = d.toLocaleDateString('en-US', opts);
      })();
    </script>
  </body>
</html>
