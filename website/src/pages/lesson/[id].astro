---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { parseSections, extractSourceUrl, parseComprehension } from '../../lib/lesson-parser';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons');
  return lessons.map(lesson => ({
    params: { id: lesson.id },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const sections = parseSections(lesson.body ?? '');
const sourceUrl = extractSourceUrl(sections.article);
const qaBlocks = parseComprehension(sections.comprehension);

// Parse vocabulary entries from sections.vocabulary
function parseVocabEntries(vocabularyText: string) {
  const entries = [];
  if (!vocabularyText.trim()) return entries;

  // Split by lines that start with ** (vocabulary entries)
  const lines = vocabularyText.split('\n');
  let currentEntry = null;

  for (const line of lines) {
    if (line.startsWith('**') && line.includes('**') && line.includes('(') && line.includes(')')) {
      // Parse: **word** (pos) （chinese）— definition
      const match = line.match(/\*\*(.*?)\*\*\s*\((.*?)\)\s*（(.*?)）\s*—\s*(.*)/);
      if (match) {
        currentEntry = {
          word: match[1],
          pos: match[2],
          chinese: match[3],
          definition: match[4],
          quote: ''
        };
        entries.push(currentEntry);
      }
    } else if (line.startsWith('>') && currentEntry) {
      // Extract quote text
      currentEntry.quote = line.replace(/^>\s*"?/, '').replace(/"?\s*$/, '');
    }
  }

  return entries;
}

// Parse expression entries from sections.expressions
function parseExpressionEntries(expressionsText: string) {
  const entries = [];
  if (!expressionsText.trim()) return entries;

  // Split into blocks by lines that start with **
  const blocks = expressionsText.split(/(?=\*\*[^*]+\*\*\s*（)/);

  for (const block of blocks) {
    if (!block.trim()) continue;

    const lines = block.trim().split('\n');
    const headerMatch = lines[0]?.match(/\*\*(.*?)\*\*\s*（(.*?)）/);

    if (headerMatch) {
      const phrase = headerMatch[1];
      const chinese = headerMatch[2];
      const explanation = [];
      const examples = [];

      for (let i = 1; i < lines.length; i++) {
        const line = lines[i].trim();
        if (line.startsWith('-')) {
          examples.push(line.substring(1).trim());
        } else if (line && !line.startsWith('**')) {
          explanation.push(line);
        }
      }

      entries.push({
        phrase,
        chinese,
        explanation: explanation.join(' '),
        examples
      });
    }
  }

  return entries;
}

const vocabEntries = parseVocabEntries(sections.vocabulary);
const expressionEntries = parseExpressionEntries(sections.expressions);

// Process article text for display (remove metadata lines)
function processArticleText(articleText: string): string[] {
  if (!articleText) return [];

  return articleText
    .split('\n\n')
    .filter(para => para.trim())
    .filter(para => !para.match(/^\d{2}-\d{2}-\d{4}/)) // Skip timestamp
    .filter(para => !para.startsWith('> Source:')) // Skip source line
    .filter(para => !para.startsWith('Difficult words:')) // Skip metadata
    .filter(para => !para.startsWith('You can watch')) // Skip metadata
    .filter(para => !para.startsWith('The post')) // Skip RSS footer noise
    .map(para => para.trim())
    .filter(para => para.length > 0);
}

const articleParagraphs = processArticleText(sections.article);
---
<Base title={lesson.id}>
  <h1 class="text-xl font-semibold mb-6">{lesson.id}</h1>

  <!-- Article section - always visible -->
  <div class="mb-8">
    {articleParagraphs.map(paragraph => (
      <p class="mb-4">{paragraph}</p>
    ))}
  </div>

  <!-- Source Link -->
  {sourceUrl && (
    <a href={sourceUrl} target="_blank" rel="noopener noreferrer"
       class="text-blue-600 text-sm underline inline-block mb-8">
      阅读原文 →
    </a>
  )}

  <!-- Vocabulary Section -->
  <div class="section-block mb-4" data-collapsed="true">
    <button class="section-header w-full text-left py-3 flex items-center justify-between min-h-[44px] text-xl font-semibold">
      <span>📚 词汇 / Vocabulary</span>
      <span class="chevron transition-transform duration-200">▼</span>
    </button>
    <div class="section-body grid transition-[grid-template-rows] duration-300 ease-out" style="grid-template-rows: 0fr">
      <div class="overflow-hidden">
        <div class="pt-4">
          {vocabEntries.map(entry => (
            <div class="border-l-4 border-blue-300 pl-3 py-2 mb-3 bg-gray-50 rounded-r">
              <div class="font-semibold">
                {entry.word} <span class="font-normal text-sm text-gray-500">({entry.pos})</span> <span class="text-sm">（{entry.chinese}）</span>
              </div>
              <div class="text-sm mt-1">{entry.definition}</div>
              {entry.quote && (
                <div class="text-xs text-gray-500 mt-1 italic">"{entry.quote}"</div>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Expressions Section -->
  <div class="section-block mb-4" data-collapsed="true">
    <button class="section-header w-full text-left py-3 flex items-center justify-between min-h-[44px] text-xl font-semibold">
      <span>🔗 表达 / Chunking Expressions</span>
      <span class="chevron transition-transform duration-200">▼</span>
    </button>
    <div class="section-body grid transition-[grid-template-rows] duration-300 ease-out" style="grid-template-rows: 0fr">
      <div class="overflow-hidden">
        <div class="pt-4">
          {expressionEntries.map(entry => (
            <div class="bg-gray-50 rounded p-3 mb-3">
              <div class="font-semibold">{entry.phrase} <span class="text-sm font-normal">（{entry.chinese}）</span></div>
              <div class="text-sm mt-1">{entry.explanation}</div>
              <ul class="text-sm mt-1 list-disc list-inside text-gray-600">
                {entry.examples.map(ex => <li>{ex}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Comprehension Section -->
  <div class="section-block mb-4" data-collapsed="true">
    <button class="section-header w-full text-left py-3 flex items-center justify-between min-h-[44px] text-xl font-semibold">
      <span>❓ 理解 / Comprehension</span>
      <span class="chevron transition-transform duration-200">▼</span>
    </button>
    <div class="section-body grid transition-[grid-template-rows] duration-300 ease-out" style="grid-template-rows: 0fr">
      <div class="overflow-hidden">
        <div class="pt-4">
          {qaBlocks.map(qa => (
            <div class="qa-block mb-4 pb-4 border-b border-gray-100">
              <p class="font-semibold mb-2">Q: {qa.question}</p>
              <div class="answer hidden">
                <p class="text-sm mt-1">{qa.answerEn}</p>
                <p class="text-sm text-gray-500 mt-1">{qa.answerZh}</p>
              </div>
              <button class="reveal-btn text-sm text-blue-600 underline min-h-[44px] px-2">查看答案</button>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    // Collapse/expand sections
    document.querySelectorAll('.section-block').forEach(function(block) {
      var btn = block.querySelector('.section-header');
      var body = block.querySelector('.section-body');
      var chevron = block.querySelector('.chevron');
      btn.addEventListener('click', function() {
        var collapsed = block.dataset.collapsed === 'true';
        body.style.gridTemplateRows = collapsed ? '1fr' : '0fr';
        chevron.style.transform = collapsed ? 'rotate(-180deg)' : '';
        block.dataset.collapsed = collapsed ? 'false' : 'true';
      });
    });

    // Tap-to-reveal answers
    document.querySelectorAll('.reveal-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var answer = btn.previousElementSibling;
        answer.classList.remove('hidden');
        btn.remove();
      });
    });

    // localStorage read tracking (PROG-01)
    (function() {
      var lessonId = document.querySelector('h1').textContent.trim();
      try {
        var stored = JSON.parse(localStorage.getItem('read_lessons') || '[]');
        if (stored.indexOf(lessonId) === -1) {
          var updated = stored.concat([lessonId]);
          localStorage.setItem('read_lessons', JSON.stringify(updated));
        }
      } catch(e) {}
    })();
  </script>
</Base>
